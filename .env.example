# Pipedrive
PIPEDRIVE_X_API_TOKEN=
PIPEDRIVE_DEFAULT_USER_ID=

# Google Sheets (fallback for @gmail.com submissions)
GMAIL_CONTACT_SPREADSHEET_ID=
GMAIL_CONTACT_SPREADSHEET_RANGE=Sheet1!A:D
GOOGLE_SERVICE_CLIENT_EMAIL=
GOOGLE_SERVICE_PRIVATE_KEY_2=

# CORS — comma-separated list of allowed origins (your Webflow domain)
ALLOWED_ORIGINS=https://www.mirumee.com,https://mirumee.com

# Teamtailor (GET /api/get-job-offers)
TEAMTAILOR_API_KEY=
# Optional — company filter on offers; omit if unused
TEAMTAILOR_COMPANY_CUSTOM_FIELD_API_ID=
